# ─────────────────────────────────────────────────────────
# ChaosMesh Arena — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Auth ─────────────────────────────────────────────────
# Single-user API key for demo access
CHAOSMESH_API_KEY=cm_demo_change_me

# ── LLM Backends ─────────────────────────────────────────
# Ollama (local, primary) — runs on OCI ARM or localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=30

# OpenRouter (cloud, secondary / fallback)
# Get your free key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_DAILY_BUDGET=200           # max requests per day (stay inside free 1000/day)

# ── Redis (message bus + cache) ───────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
LLM_CACHE_TTL_SECONDS=3600
LLM_CACHE_RECENT_LIMIT=200

# ── Persistence ──────────────────────────────────────────
CHROMADB_PATH=./data/chromadb         # embedded mode, SQLite backend
SQLITE_PATH=./data/sqlite/episodes.db

# ── Server ───────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=["http://localhost:7860","http://localhost:3000"]

# ── Episode Limits ────────────────────────────────────────
MAX_EPISODE_MESSAGES=50               # hard cap on inter-agent messages per episode
MAX_EPISODE_WALL_SECONDS=30           # demo mode: 30s real-time limit
MAX_SIM_MINUTES=15                    # simulated time per episode
DEMO_FAST_MAX_STEPS=8
DEMO_FAST_WALL_SECONDS=20

# LLM fallback timeout tuning (demo mode)
OLLAMA_TIMEOUT_DEMO_SECONDS=8
OPENROUTER_TIMEOUT_DEMO_SECONDS=6

# ── Demo Mode ────────────────────────────────────────────
DEMO_MODE=false                       # true = use pre-scripted fast-paths
LOG_LEVEL=INFO

# HF Space warm keeper
HF_SPACE_BASE_URL=
HF_WARM_KEEPER_INTERVAL_SECONDS=240
