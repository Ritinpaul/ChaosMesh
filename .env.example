# ============================================================
# ChaosMesh Arena — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Auth ─────────────────────────────────────────────────────
# Legacy single-key mode (for demo / local dev only)
# In production, leave empty and use JWT auth via /auth/register
CHAOSMESH_API_KEY=

# JWT Secret — MUST be set in production (min 32 random chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_secrets_token_hex_32

JWT_EXPIRE_HOURS=24

# ── Database ─────────────────────────────────────────────────
# Local dev: leave as is (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/chaosmesh.db

# Production (Postgres): uncomment and fill
# POSTGRES_URL=postgresql+asyncpg://user:password@host:5432/chaosmesh

# ── LLM — Ollama (primary, local) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_TIMEOUT_DEMO_SECONDS=8

# ── LLM — OpenRouter (secondary, cloud) ───────────────────────
# Get key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_DAILY_BUDGET=200
OPENROUTER_TIMEOUT_DEMO_SECONDS=6

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
LLM_CACHE_TTL_SECONDS=3600
LLM_CACHE_RECENT_LIMIT=200

# ── Persistence ──────────────────────────────────────────────
CHROMADB_PATH=./data/chromadb
SQLITE_PATH=./data/sqlite/episodes.db

# ── Server ───────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS origins (comma-separated, no wildcards with credentials)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:7860

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_ENV=30/minute

# ── Session & Episode Limits ──────────────────────────────────
MAX_CONCURRENT_SESSIONS=50
SESSION_TTL_SECONDS=1800
MAX_EPISODE_MESSAGES=50
MAX_EPISODE_WALL_SECONDS=30
MAX_SIM_MINUTES=15
FREE_PLAN_EPISODES_PER_MONTH=100

# ── Hugging Face Space (set only when deploying to HF) ────────
# HF_SPACE_BASE_URL=https://your-space.hf.space
HF_SPACE_BASE_URL=

# ── Demo / Debug ─────────────────────────────────────────────
DEMO_MODE=false
LOG_LEVEL=INFO

# ── Hackathon Inference (required) ───────────────────────────
# Used by root inference.py (OpenAI client invocation)
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=
